<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
    "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
    "https://checkstyle.org/dtds/suppressions_1_2.dtd">

<suppressions>
    <!-- テストメソッドは日本語＋アンダースコアの命名を許容する -->
    <suppress checks="MethodName" files=".*Test\.java"/>
    <!-- SLF4J Logger フィールド（static final log）は ConstantName 対象外 -->
    <suppress checks="ConstantName" message="Name 'log' must match pattern"/>
</suppressions>
