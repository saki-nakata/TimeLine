<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.timeline.mapper.UserMapper">

    <resultMap id="UserResultMap" type="com.timeline.model.User">
        <id     property="id"             column="id"/>
        <result property="username"       column="username"/>
        <result property="displayName"    column="display_name"/>
        <result property="email"          column="email"/>
        <result property="passwordHash"   column="password_hash"/>
        <result property="oauthProvider"  column="oauth_provider"/>
        <result property="oauthId"        column="oauth_id"/>
        <result property="avatarUrl"      column="avatar_url"/>
        <result property="bio"            column="bio"/>
        <result property="followerCount"  column="follower_count"/>
        <result property="followingCount" column="following_count"/>
        <result property="createdAt"      column="created_at"/>
        <result property="updatedAt"      column="updated_at"/>
    </resultMap>

    <select id="findByEmail" parameterType="string" resultMap="UserResultMap">
        SELECT * FROM users WHERE email = #{email} LIMIT 1
    </select>

    <select id="findByUsername" parameterType="string" resultMap="UserResultMap">
        SELECT * FROM users WHERE username = #{username} LIMIT 1
    </select>

    <select id="findById" parameterType="long" resultMap="UserResultMap">
        SELECT * FROM users WHERE id = #{id} LIMIT 1
    </select>

    <insert id="insert" parameterType="com.timeline.model.User" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO users (username, display_name, email, password_hash, oauth_provider, oauth_id, avatar_url, bio)
        VALUES (#{username}, #{displayName}, #{email}, #{passwordHash}, #{oauthProvider}, #{oauthId}, #{avatarUrl}, #{bio})
    </insert>

</mapper>
