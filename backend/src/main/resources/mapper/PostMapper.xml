<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.timeline.mapper.PostMapper">

    <resultMap id="PostResultMap" type="com.timeline.model.Post">
        <id     property="id"        column="id"/>
        <result property="userId"    column="user_id"/>
        <result property="content"   column="content"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <resultMap id="PostResponseResultMap" type="com.timeline.dto.PostResponse">
        <id     property="id"          column="id"/>
        <result property="userId"      column="user_id"/>
        <result property="username"    column="username"/>
        <result property="displayName" column="display_name"/>
        <result property="avatarUrl"   column="avatar_url"/>
        <result property="content"     column="content"/>
        <result property="createdAt"   column="created_at"/>
        <result property="updatedAt"   column="updated_at"/>
    </resultMap>

    <insert id="insert" parameterType="com.timeline.model.Post" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO posts (user_id, content, created_at, updated_at)
        VALUES (#{userId}, #{content}, #{createdAt}, #{updatedAt})
    </insert>

    <select id="findById" parameterType="long" resultMap="PostResultMap">
        SELECT * FROM posts WHERE id = #{id} LIMIT 1
    </select>

    <select id="findTimeline" resultMap="PostResponseResultMap">
        SELECT p.id, p.user_id, p.content, p.created_at, p.updated_at,
               u.username, u.display_name, u.avatar_url
        FROM posts p
        JOIN users u ON p.user_id = u.id
        <if test="cursor != null">
            WHERE p.id &lt; #{cursor}
        </if>
        ORDER BY p.id DESC
        LIMIT #{limit}
    </select>

    <update id="update" parameterType="com.timeline.model.Post">
        UPDATE posts SET content = #{content}, updated_at = #{updatedAt}
        WHERE id = #{id}
    </update>

    <delete id="delete" parameterType="long">
        DELETE FROM posts WHERE id = #{id}
    </delete>

</mapper>
