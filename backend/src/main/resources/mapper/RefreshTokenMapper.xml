<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.timeline.mapper.RefreshTokenMapper">

    <resultMap id="RefreshTokenResultMap" type="com.timeline.model.RefreshToken">
        <id     property="id"        column="id"/>
        <result property="userId"    column="user_id"/>
        <result property="tokenHash" column="token_hash"/>
        <result property="expiresAt" column="expires_at"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <insert id="insert" parameterType="com.timeline.model.RefreshToken" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO refresh_tokens (user_id, token_hash, expires_at)
        VALUES (#{userId}, #{tokenHash}, #{expiresAt})
    </insert>

    <select id="findByTokenHash" parameterType="string" resultMap="RefreshTokenResultMap">
        SELECT * FROM refresh_tokens WHERE token_hash = #{tokenHash} LIMIT 1
    </select>

    <delete id="deleteByTokenHash" parameterType="string">
        DELETE FROM refresh_tokens WHERE token_hash = #{tokenHash}
    </delete>

    <delete id="deleteByUserId" parameterType="long">
        DELETE FROM refresh_tokens WHERE user_id = #{userId}
    </delete>

</mapper>
